<?xml version="1.0"?>
<launch>
  <let name="urdf_file" value="$(find-pkg-share robo_nemotron_description)/urdf/robo_nemotron.urdf" />

  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher">
    <param name="robot_description" value="$(file-content $(var urdf_file))" type="str" />
  </node>

  <node pkg="robo_nemotron_motion" exec="trajectory_generator" name="trajectory_generator" output="screen" />

  <node pkg="rviz2" exec="rviz2" name="rviz2" args="-d $(find-pkg-share robo_nemotron_description)/config/config.rviz" />
</launch>
