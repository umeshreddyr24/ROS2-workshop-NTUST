<?xml version="1.0"?>
<robot name="robo_nemotron">

  <link name="base_link">
    <visual>
      <geometry><cylinder length="0.6" radius="0.2"/></geometry>
      <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.6" radius="0.2"/></geometry>
    </collision>
  </link>

  <link name="link_1">
    <visual>
      <origin xyz="0 0 0.25"/>
      <geometry><cylinder length="0.5" radius="0.1"/></geometry>
      <material name="white"><color rgba="1.0 1.0 1.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.25"/>
      <geometry><cylinder length="0.5" radius="0.1"/></geometry>
    </collision>
  </link>

  <link name="link_2">
    <visual>
      <origin xyz="0 0 0.25"/>
      <geometry><cylinder length="0.5" radius="0.08"/></geometry>
      <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.25"/>
      <geometry><cylinder length="0.5" radius="0.08"/></geometry>
    </collision>
  </link>

  <link name="link_3">
    <visual>
      <origin xyz="0 0 0.2"/>
      <geometry><cylinder length="0.4" radius="0.06"/></geometry>
      <material name="white"><color rgba="1.0 1.0 1.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.2"/>
      <geometry><cylinder length="0.4" radius="0.06"/></geometry>
    </collision>
  </link>

  <link name="gripper_base">
    <visual>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
      <material name="yellow"><color rgba="1.0 1.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
    </collision>
  </link>

  <link name="left_finger">
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><box size="0.02 0.02 0.1"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry><box size="0.02 0.02 0.1"/></geometry>
    </collision>
  </link>

  <link name="right_finger">
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><box size="0.02 0.02 0.1"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry><box size="0.02 0.02 0.1"/></geometry>
    </collision>
  </link>

  <joint name="arm_0_joint" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <joint name="arm_1_joint" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.5"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <joint name="arm_2_joint" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.5"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <joint name="gripper_fixed_joint" type="fixed">
    <parent link="link_3"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
  </joint>

  <joint name="gripper_1_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="-0.08 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.05" effort="5" velocity="0.5"/>
  </joint>

  <joint name="gripper_2_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="0.08 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0.0" upper="0.05" effort="5" velocity="0.5"/>
  </joint>

</robot>
